class Solution:
    def maxTaskAssign(self, tasks: List[int], workers: List[int], pills: int, strength: int) -> int:
        n=len(tasks)
        m=len(workers)
        l=0
        r=min(n,m)
        ans=0
        tasks.sort()
        workers.sort(reverse=True)
        while l<=r:
            m=l+(r-l)//2
            if self.check(m,tasks,workers,pills,strength):
                ans=m
                l=m+1
            else:
                r=m-1
        return ans

    def check(self,m,tasks,workers,pills,strength):
        st=SortedList(workers[:m])
        pillsused=0
        i=m-1
        while i>=0:
            req=tasks[i]
            if st[-1]>=req:
                st.pop()
            elif pillsused >= pills:
                return False
            else:
                re=req - strength

                idx=st.bisect_left(re)
                if idx==len(st):
                    return False

                st.pop(idx)
                pillsused += 1

            i=i-1

        return True
                

